<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_image">

    <!-- TextView to the Right of the Image -->

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Der Schnee, das Feuer, die Schuld und der Tod"
        android:textSize="23sp"
        android:textColor="@android:color/white"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="4dp"
        android:layout_above="@id/cardView"/>
    <TextView
        android:id="@+id/txtAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gerhard Jäger"
        android:textSize="26sp"
        android:textColor="@android:color/white"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="25dp" />
    <!-- Image on the Left Below White Bar -->
    <ImageView
        android:id="@+id/imgCover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/cover"
        android:layout_below="@id/txtAuthor"
        android:layout_above="@id/txtTitle"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        tools:ignore="NotSibling" />

    <!-- Box Above the Input with a TextView Inside -->

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="200pt"
        android:layout_height="wrap_content"
        android:layout_above="@+id/bottom_nav"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:background="@android:color/white">

        <!-- Vertical Layout for Text Items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            tools:ignore="ExtraText">

            <!-- Short Description -->
            <TextView
                android:id="@+id/txtDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A thrilling journey through space..."
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:layout_marginTop="4dp" />

            <!-- Rating -->
            <RatingBar
                android:id="@+id/rbRating"
                android:layout_width="73pt"
                android:layout_height="wrap_content"
                android:numStars="10"
                android:rating="0"
                android:layout_marginTop="4dp"
                android:layout_marginLeft="10pt"
                android:layout_alignParentTop="true"
                style="?android:attr/ratingBarStyleSmall"
                android:scaleX="1.3"
                android:scaleY="1.5"/>

            <!-- Genre -->
            <TextView
                android:id="@+id/txtGenre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Genre: Science Fiction"
                android:textSize="18sp"
                android:textColor="@android:color/black" />

            <!-- Page Count -->
            <TextView
                android:id="@+id/txtPageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pages: 432"
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Nav-bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center">

            <ImageButton
                android:id="@+id/nav_home"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@null"
                android:src="@drawable/ic_home"
                android:contentDescription="Home" />

            <ImageButton
                android:id="@+id/nav_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@null"
                android:src="@drawable/ic_search"
                android:contentDescription="Search" />

            <ImageButton
                android:id="@+id/nav_stats"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@null"
                android:src="@drawable/ic_stats"
                android:contentDescription="Stats" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>
