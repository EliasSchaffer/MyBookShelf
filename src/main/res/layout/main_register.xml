<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/background2">

    <!-- Register Title -->
    <TextView
        android:id="@+id/txtRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerInParent="true"
        android:text="Register"
        android:textColor="@android:color/black"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_above="@id/cardView"/>

    <!-- CardView for the Textitems -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@android:color/white">

            <!-- Email Label -->
            <TextView
                android:id="@+id/txtEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email: "
                android:textSize="23sp"
                android:textStyle="bold"
                android:layout_marginTop="26dp"
                android:layout_marginLeft="2dp"
                android:textColor="@android:color/black" />

            <!-- Email Input Field -->
            <EditText
                android:id="@+id/txfEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:textSize="18sp"
                android:background="@drawable/rounded_edittext"
                android:inputType="textPersonName"
                android:layout_below="@id/txtEmail"
                android:layout_marginBottom="6dp"/>

            <!-- Username Label -->
            <TextView
                android:id="@+id/txtUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username: "
                android:textSize="23sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:layout_marginLeft="2dp"
                android:textColor="@android:color/black"
                android:layout_below="@id/txfEmail"/>

            <!-- Username Input Field -->
            <EditText
                android:id="@+id/txfUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:textSize="18sp"
                android:background="@drawable/rounded_edittext"
                android:inputType="textPersonName"
                android:layout_below="@id/txtUsername"
                android:layout_marginBottom="6dp" />

            <!-- Password Label -->
            <TextView
                android:id="@+id/txtNewPasswd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password: "
                android:textStyle="bold"
                android:textSize="23sp"
                android:textColor="@android:color/black"
                android:layout_below="@id/txfUser"
                android:layout_margin="2dp"/>

            <!-- Password Input Field -->
            <EditText
                android:id="@+id/txfNewPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtNewPasswd"
                android:inputType="textPassword"
                android:padding="10dp"
                android:textSize="18sp"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="6dp"/>

            <!-- Repeat Password Label -->
            <TextView
                android:id="@+id/txtRepeatPasswd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repeat Password: "
                android:textSize="23sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_below="@id/txfNewPassword"
                android:layout_margin="2dp"/>

            <!-- Repeat Password Input Field -->
            <EditText
                android:id="@+id/txfRepeatPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtRepeatPasswd"
                android:inputType="textPassword"
                android:padding="10dp"
                android:textSize="18sp"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="16dp"/>

            <!-- Register Button -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/txfRepeatPassword"
                android:layout_alignParentEnd="true"
                android:background="@drawable/rounded_button"
                android:text="OK"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginTop="16dp"/>

            <!-- Back to Login Button -->
            <Button
                android:id="@+id/btnBackLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_below="@id/txfRepeatPassword"
                android:background="@drawable/rounded_button"
                android:text="Back to Login"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginTop="16dp"/>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>
