<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/goalPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Goal Input Section -->
    <TextView
        android:id="@+id/tvAddGoal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Goal"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etNewGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter your goal" />

    <Button
        android:id="@+id/btnAddGoal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Goal"
        android:layout_marginTop="8dp" />

    <!-- Current Goals Section -->
    <TextView
        android:id="@+id/tvCurrentGoals"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current Goals"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCurrentGoals"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Completed Goals Section -->
    <TextView
        android:id="@+id/tvCompletedGoals"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Completed Goals"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCompletedGoals"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
